KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_password
KITE_TOTP_SECRET=your_totp_base32_secret

SEED_CAPITAL=1000.0
RISK_PER_TRADE_PCT=0.25
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_PCT=0.04
PROFIT_LOCK_PCT=0.08
MIS_LEVERAGE=3

DB_PATH=ledger/trades.db
TOKEN_PATH=auth/.session_token

# AI Brain Selection
ACTIVE_AI_BRAIN=gemini

# Claude AI brain (get key from console.anthropic.com)
ANTHROPIC_API_KEY=
CLAUDE_TRADE_MODEL=claude-opus-4-7
CLAUDE_MONITOR_MODEL=claude-sonnet-4-6

# Gemini AI brain (get free key from aistudio.google.com)
GEMINI_API_KEY=
GEMINI_TRADE_MODEL=gemini-2.5-pro
GEMINI_MONITOR_MODEL=gemini-2.5-flash

DRY_RUN=true
LOG_LEVEL=INFO
